# Lark Custom App credentials (from https://open.larksuite.com/app)
LARK_APP_ID=cli_xxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: use China region instead
# LARK_BASE_URL=https://open.feishu.cn

# Optional: user access token (OAuth) — required to read a person's primary calendar
# LARK_USER_ACCESS_TOKEN=u-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
