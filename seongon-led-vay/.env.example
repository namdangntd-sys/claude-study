# Required: Anthropic API key for the AI design generator
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Email báo giá (Resend) — không có 2 vars này thì /api/quote trả 503.
# 1. Đăng ký miễn phí ở https://resend.com/signup
# 2. Lấy API key tại https://resend.com/api-keys (bắt đầu bằng "re_")
RESEND_API_KEY=re_...
# Email nhận yêu cầu báo giá (gửi tới chủ shop)
QUOTE_TO_EMAIL=shop-owner@example.com
# Tuỳ chọn: địa chỉ gửi đi. Mặc định dùng "onboarding@resend.dev" (Resend sandbox, không cần verify domain).
# Để dùng domain riêng, verify domain trên Resend rồi đổi sang "SEONGON SG <noreply@domain.com>".
QUOTE_FROM_EMAIL=SEONGON SG <onboarding@resend.dev>

# Optional: Port (Railway sets this automatically)
PORT=3000
